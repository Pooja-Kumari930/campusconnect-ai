NODE_ENV=development
PORT=5000

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/campusconnect?retryWrites=true&w=majority

# JWT secrets - use long random strings in production
JWT_ACCESS_SECRET=replace_with_a_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_a_long_random_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Frontend origin (for CORS + cookies)
CLIENT_URL=http://localhost:5173

# AI provider (added in a later phase)
GEMINI_API_KEY=
